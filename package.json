{
  "name": "readme-health",
  "version": "0.2.0",
  "description": "A local CLI that scores README files for maintainer readiness.",
  "type": "module",
  "homepage": "https://github.com/duhman/readme-health#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duhman/readme-health.git"
  },
  "bugs": {
    "url": "https://github.com/duhman/readme-health/issues"
  },
  "bin": {
    "readme-health": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "readme",
    "markdown",
    "cli",
    "oss",
    "health-check"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
